{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "keymacro",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/keymacro.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "QT_QPA_PLATFORM": "wayland",
                "WAYLAND_DISPLAY": "${env:WAYLAND_DISPLAY}"
            },
            "justMyCode": false
        }
    ]
}
