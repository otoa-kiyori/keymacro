# keymacro — Logitech G600 Gaming Mouse udev rules
#
# Grants evdev input access to members of the 'input' group,
# so the G600 plugin can read and grab device events without root.
#
# Install with:
#   bash scripts/install-udev-rules.sh
#
# Group membership required:
#   sudo usermod -aG input $USER
#   Then log out and back in.

# Logitech G600 Gaming Mouse — evdev interfaces (G600 plugin)
SUBSYSTEM=="input", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c24a", GROUP="input", MODE="0660"
