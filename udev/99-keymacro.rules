# keymacro core udev rules
#
# This file covers the uinput virtual device, required by all keymacro plugins.
# Device-specific rules live alongside each plugin:
#   plugins/g13/99-keymacro-g13.rules
#   plugins/g600/99-keymacro-g600.rules
#
# Install everything with:
#   bash scripts/install-udev-rules.sh
#
# Group membership required:
#   sudo usermod -aG input,plugdev $USER
#   Then log out and back in.

# /dev/uinput — virtual input device creation (needed by all plugins)
KERNEL=="uinput", GROUP="input", MODE="0660"
